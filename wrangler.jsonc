{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "herorank",
  "compatibility_date": "2026-06-12",
  // nodejs_compat: required so Better Auth / Stripe SDK Node-shim code paths resolve on Workers.
  "compatibility_flags": ["nodejs_compat"],

  // ─── Workers Static-Assets mode (Phase 4, Engineer A) ───────────────────────
  // Migrated off legacy Cloudflare Pages (`pages_build_output_dir`) so the deploy
  // can run Cron Triggers + a Queue consumer (Pages supports NEITHER).
  //   `main`   → our custom worker entry (re-exports SvelteKit `fetch`, adds
  //              `scheduled` + `queue`). The adapter does NOT overwrite this file:
  //              it builds against `wrangler.adapter.jsonc` (no `main`) and emits
  //              `.svelte-kit/cloudflare/_worker.js`, which `src/worker.ts` imports.
  //   `assets` → SvelteKit client build + prerendered pages, served by the ASSETS
  //              binding. SSR/SPA routing is handled inside the generated worker.
  "main": "src/worker.ts",
  "assets": {
    "directory": ".svelte-kit/cloudflare",
    "binding": "ASSETS"
  },
  "observability": { "enabled": true },

  // Smart Placement: run the Worker near D1 (APAC) instead of near the user, so the
  // multiple per-request D1 queries (auth/session) become low-latency in-region hops.
  "placement": { "mode": "smart" },

  // --- Non-secret environment vars ---
  "vars": {
    "LLM_BASE_URL": "https://vtoken.viemind.ai/v1",
    "LLM_MODEL": "gemini-3.5-flash-high",
    "ETSY_DAILY_CAP": "4500",
    "ETSY_CRON_CAP": "1000"
  },

  // --- D1 (primary datastore: users, sessions, subscriptions, credits) ---
  "d1_databases": [
    {
      "binding": "DB",
      "database_name": "herorank",
      // Placeholder id for local dev; replace with real id when a Cloudflare account exists.
      "database_id": "e8a41229-da9f-45cd-83d0-a755b22bc159",
      "migrations_dir": "migrations"
    }
  ],

  // --- KV (Phase 2/3 cache: etsy responses, sessions) ---
  "kv_namespaces": [
    {
      "binding": "KV",
      "id": "191fae0f88ae4b73823acb0c02c14d6c"
    }
  ],

  // --- Cron Triggers (Phase 4, Engineer A — dispatched in src/worker.ts → handleScheduled) ──
  // One `scheduled` handler branches on `controller.cron`:
  //   "*/30 * * * *" → rank-track sweep (Phase 4 §1.3): re-check tracked_listings
  //                    due for refresh (24h-per-listing guard), within ETSY_CRON_CAP.
  //   "0 1 * * 0"    → weekly Etsy taxonomy refresh        (Phase 3 cron, folds in here)
  //   "0 2 * * 0"    → weekly Etsy trends refresh          (Phase 3 cron)
  //   "0 3 * * 0"    → weekly Etsy best-sellers refresh    (Phase 3 cron)
  //   "0 4 * * 0"    → weekly OAuth calibration job        (Phase 4 §3.4, Engineer H logic)
  "triggers": {
    "crons": ["*/30 * * * *", "0 4 * * 7"]
  },

  // --- Queues (Phase 4, Engineer A) ─────────────────────────────────────────
  // Deep shop analysis (§2): producer enqueues a job, consumer (src/worker.ts
  // → handleQueue) processes it off the request path. Producer binding is
  // ANALYSIS_QUEUE; when absent (plain `vite dev`) the producer falls back to
  // inline `waitUntil` (BR-P4-Q-03).
  "queues": {
    "producers": [
      { "binding": "ANALYSIS_QUEUE", "queue": "herorank-analysis" }
    ],
    "consumers": [
      {
        "queue": "herorank-analysis",
        "max_batch_size": 5,
        "max_batch_timeout": 30,
        "max_retries": 3,
        "dead_letter_queue": "herorank-analysis-dlq"
      },
      // DLQ consumer (Phase 5, R3 P0) — herorank-analysis-dlq previously had NO consumer,
      // causing failed jobs to stay stuck in 'running'/'deferred' state silently.
      // This consumer marks the analyses row 'failed' and emits a logError alert.
      // No max_retries here — DLQ messages are always acked (terminal, never re-queued).
      {
        "queue": "herorank-analysis-dlq",
        "max_batch_size": 5,
        "max_batch_timeout": 30,
        "max_retries": 0
      }
    ]
  }
}
