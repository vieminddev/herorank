# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# sveltekit / cloudflare
.svelte-kit
.wrangler
# wrangler local secrets (BETTER_AUTH_SECRET, STRIPE_*, ...)
.dev.vars
.dev.vars.*

# production
/build

# misc
.DS_Store
*.pem

# test / QA scratch (local artifacts, not source)
/screenshots
/test-results
/playwright-report
/playwright-session.json
/playwright-state-*.json
/_workspaces

# recovery scratch
herorank.zip
herorank-bundle.zip

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*
!.env.example

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

# dev server + scan scratch logs
.dev-server.log
.dev-server.err.log
scripts/out/_*.log
