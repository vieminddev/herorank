FIRECRAWL_API_KEY=

# NOTE: On Cloudflare Workers / `wrangler dev`, runtime secrets are read from `.dev.vars`
# (NOT .env). Copy these keys into a local `.dev.vars` file (gitignored) for dev.

# --- Auth (Better Auth) ---
# Generate: openssl rand -base64 32
BETTER_AUTH_SECRET=
# Optional explicit origin override; defaults to the incoming request origin.
BETTER_AUTH_URL=http://localhost:5173

# --- Stripe (Eng B) ---
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
# Price IDs (3 plans x 2 periods) — fill from Stripe test dashboard.
STRIPE_PRICE_SIDE_MONTHLY=
STRIPE_PRICE_SIDE_YEARLY=
STRIPE_PRICE_BUSINESS_MONTHLY=
STRIPE_PRICE_BUSINESS_YEARLY=
STRIPE_PRICE_ENTERPRISE_MONTHLY=
STRIPE_PRICE_ENTERPRISE_YEARLY=

# --- LLM gateway (Phase 2) ---
LLM_BASE_URL=https://vtoken.viemind.ai/v1
LLM_API_KEY=
# Gateway model name (OpenAI-compatible). Required for any LLM tool to work.
LLM_MODEL=

# --- Etsy data (Phase 3) ---
ETSY_API_KEY=
ETSY_API_SECRET=

# --- Phase 4: jobs + OAuth ---
# AES-GCM key (base64, 32 bytes) for encrypting OAuth tokens at rest in D1.
# Generate: openssl rand -base64 32 . Workers secret in prod (`wrangler secret put OAUTH_TOKEN_KEY`).
OAUTH_TOKEN_KEY=
# Etsy OAuth app credentials (absent → mock OAuth provider). Engineer H wires the flow.
ETSY_OAUTH_CLIENT_ID=
ETSY_OAUTH_CLIENT_SECRET=
# Absolute callback URL registered with the Etsy app.
ETSY_OAUTH_REDIRECT_URI=http://localhost:8788/api/connect/etsy/callback
# NOTE: the ANALYSIS_QUEUE producer binding is configured in wrangler.jsonc (queues.producers),
# not here — it is a binding, not a secret. Local `wrangler dev` provides it automatically.

# --- Phase 5: rate-limit overrides + observability (INFRA-EDGE) ---
# Optional plain vars (NOT secrets). Absent → soft-beta defaults in
# src/lib/server/api/middleware/rateLimit.ts (llm 30/h/user, general 120/min/IP, auth 10/15min/IP).
RATE_LIMIT_LLM_PER_HOUR=
RATE_LIMIT_GENERAL_PER_MIN=
RATE_LIMIT_AUTH_PER_15MIN=
# NOTE: the ANALYTICS binding (Analytics Engine dataset, Cloudflare-native observability) is a
# wrangler.jsonc binding (`analytics_engine_datasets`, binding name "ANALYTICS"), not a secret.
# Optional — when absent the structured logger still emits JSON console lines (Workers Logs).
