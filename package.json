{
  "name": "herorank",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite dev",
    "build": "vite build",
    "preview": "vite preview",
    "check": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
    "test": "vitest run",
    "test:watch": "vitest",
    "e2e": "playwright test",
    "auth:generate": "better-auth generate --config src/lib/server/auth-cli.ts --output migrations/0001_better_auth.sql",
    "db:migrate:local": "wrangler d1 migrations apply herorank --local",
    "ext:zip": "node scripts/zip-extension.mjs"
  },
  "dependencies": {
    "@better-auth/utils": "^0.4.1",
    "better-auth": "^1.6.16",
    "clsx": "^2.1.1",
    "hono": "^4.12.0",
    "kysely": "^0.29.0",
    "kysely-d1": "^0.4.0",
    "lucide-svelte": "^0.469.0",
    "mp4-muxer": "^5.2.2",
    "stripe": "^22.2.0",
    "zod": "^4.3.6"
  },
  "overrides": {
    "better-call": "1.3.6"
  },
  "devDependencies": {
    "@better-auth/cli": "^1.4.22",
    "@cloudflare/workers-types": "^4.20260612.1",
    "@fontsource/geist-mono": "^5.1.1",
    "@fontsource/geist-sans": "^5.1.1",
    "@fontsource/inter": "^5.1.1",
    "@mendable/firecrawl-js": "^4.25.3",
    "@opentelemetry/api": "^1.9.1",
    "@playwright/test": "^1.60.0",
    "@sveltejs/adapter-cloudflare": "^7.0.0",
    "@sveltejs/kit": "^2.15.0",
    "@sveltejs/vite-plugin-svelte": "^5.0.3",
    "@tailwindcss/vite": "^4.0.0",
    "@types/better-sqlite3": "^7.6.11",
    "@types/node": "^22.10.0",
    "better-sqlite3": "^11.8.0",
    "svelte": "^5.16.0",
    "svelte-check": "^4.1.1",
    "tailwindcss": "^4.0.0",
    "typescript": "^5.7.0",
    "vite": "^6.0.0",
    "vitest": "^4.1.8",
    "wrangler": "^4.99.0"
  }
}
